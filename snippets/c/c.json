{
  "C-FileHeaderComments": {
    "prefix": "fhc",
    "description": "File header comment",
    "body": [
      "/*",
      " * Copyright (c) $CURRENT_YEAR Oswin",
      " * SPDX-License-Identifier: MIT",
      " *",
      " * File: ${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2}/}/${TM_FILENAME}",
      " * Author: Oswin <ouzw.mail@gmail.com>",
      " */"
    ]
  },
  "C-FileGuard": {
    "prefix": "fg",
    "description": "File guard",
    "body": [
      "#ifndef ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H_",
      "#define ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H_",
      "#ifdef __cplusplus",
      "extern \"C\" {",
      "#endif /* __cplusplus */",
      "",
      "${0}",
      "",
      "#ifdef __cplusplus",
      "}",
      "#endif /* __cplusplus */",
      "#endif /* ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H_ */"
    ]
  }
}
