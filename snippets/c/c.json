{
  "C-FileHeaderComments": {
    "prefix": "fhc",
    "description": "File header comment",
    "body": [
      "/*",
      " * Copyright (c) $CURRENT_YEAR Oswin",
      " * SPDX-License-Identifier: MIT",
      " *",
      " * File: ${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2}/}/${TM_FILENAME}",
      " * Author: Oswin <ouzw.mail@gmail.com>",
      " */",
      ""
    ]
  },
  "WorkFileHeaderComments": {
    "prefix": "wfhc",
    "description": "File header comment",
    "body": [
      "/*",
      " * Copyright (c) $CURRENT_YEAR Intretech Ltd.",
      " *",
      " * File: ${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2}/}/${TM_FILENAME}",
      " * Author: Oswin <oswin_ou@intretech.com>",
      " */",
      ""
    ]
  },
  "C-FileGuard": {
    "prefix": "fg",
    "description": "File guard",
    "body": [
      "#ifndef __${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2:/upcase}/}_${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H",
      "#define __${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2:/upcase}/}_${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H",
      "#ifdef __cplusplus",
      "extern \"C\" {",
      "#endif /* __cplusplus */",
      "",
      "${0}",
      "",
      "#ifdef __cplusplus",
      "}",
      "#endif /* __cplusplus */",
      "#endif /* __${TM_DIRECTORY/(.*[\\\\\\/])?([^\\\\\\/]+)$/${2:/upcase}/}_${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H */",
      ""
    ]
  }
}
